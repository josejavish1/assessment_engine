#!/usr/bin/env bash
set -euo pipefail
echo "🔥 INICIANDO OPERACIÓN TIERRA QUEMADA (Chaos Engineering) 🔥"
chaos_dir=$(mktemp -d)
cp -a "." "$chaos_dir/"
cd "$chaos_dir"
rm -rf src/assessment_engine/adapters
export SOVEREIGN_LLM_PROVIDER="fake"
source .venv/bin/activate
if pytest tests/; then
    echo "✅ Zero Vendor Lock-in garantizado."
    exit 0
else
    echo "❌ Vendor Lock-in detectado."
    exit 1
fi
